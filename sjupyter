#!/bin/bash
# =============================================================================
# sjupyter - Production Jupyter-on-Slurm launcher with idle killer
# =============================================================================

set -eo pipefail

# ---- Jupyter executable detection -------------------------------------------
if [ -z "${JUPYTER_PATH:-}" ]; then
    JUPYTER_PATH=$(which jupyter-lab 2>/dev/null || which jupyter-notebook 2>/dev/null || which jupyter 2>/dev/null)
    if [ -z "${JUPYTER_PATH}" ]; then
        echo "Error: Could not find jupyter-lab, jupyter-notebook, or jupyter on PATH."
        exit 1
    fi
fi
export JUPYTER_PATH

# ---- sjupyter directories ---------------------------------------------------
export SJUPYTER_USER_DIR="${HOME}/.sjupyter"
mkdir -p "${SJUPYTER_USER_DIR}/jobs"

CURRENTDIR=$(pwd)
SJUPYTER_TMPFILE=$(mktemp -p "${SJUPYTER_USER_DIR}")
export PYTHONWARNINGS="ignore::DeprecationWarning:traitlets"

# Detect which jupyter module the user has loaded
SJUPYTER_MODULE=$(module list 2>&1 | grep -oE 'anaconda[^ ]+|Miniforge[^ ]+|miniconda[^ ]+' | head -1)
if [ -z "${SJUPYTER_MODULE}" ]; then
    echo "Error: No anaconda/Miniforge module loaded. Please load a module first."
    echo "Example: ml Miniforge-24.7.1-2"
    exit 1
fi
echo "Using module: ${SJUPYTER_MODULE}"

# ---- Submit batch job -------------------------------------------------------
sbatch \
  --export=ALL,IDLE_TIMEOUT=${IDLE_TIMEOUT:-3600},IDLE_POLL_INTERVAL=${IDLE_POLL_INTERVAL:-60},HTTP_PROXY=http://gw-srv-01.rc.zi.columbia.edu:3128,HTTPS_PROXY=http://gw-srv-01.rc.zi.columbia.edu:3128,http_proxy=http://gw-srv-01.rc.zi.columbia.edu:3128,https_proxy=http://gw-srv-01.rc.zi.columbia.edu:3128,PYTHONWARNINGS=ignore::DeprecationWarning \
  --chdir="${CURRENTDIR}" \
  --output="${SJUPYTER_USER_DIR}/jobs/%j.out" \
  --error="${SJUPYTER_USER_DIR}/jobs/%j.out" \
  "$@" --parsable <<'EOF' > "${SJUPYTER_TMPFILE}"
#!/bin/bash
#SBATCH --job-name=jupyter
#SBATCH --no-requeue

set -euo pipefail

cd "${SLURM_SUBMIT_DIR:-$HOME}"
if ! type module &>/dev/null 2>&1; then
    for init_path in \
        /share/lmod/lmod/init/bash \
        /etc/profile.d/modules.sh \
        /usr/share/lmod/lmod/init/bash
    do
        if [ -f "${init_path}" ]; then
            source "${init_path}"
            break
        fi
    done
fi

if [ -n "${SJUPYTER_MODULE:-}" ]; then
    module load ${SJUPYTER_MODULE}
fi

# ---- Runtime dirs -----------------------------------------------------------
export XDG_RUNTIME_DIR=""
export JUPYTER_RUNTIME_DIR="${HOME}/.local/share/jupyter/runtime"
mkdir -p "${JUPYTER_RUNTIME_DIR}"

# ---- Proxy (inherit from submit env if present) -----------------------------
export HTTP_PROXY="${HTTP_PROXY:-}"
export HTTPS_PROXY="${HTTPS_PROXY:-}"
export http_proxy="${HTTP_PROXY:-}"
export https_proxy="${HTTPS_PROXY:-}"
export NO_PROXY="${NO_PROXY:-localhost,127.0.0.1,::1}"

# ---- IP / port selection ----------------------------------------------------
IP=$(hostname -i)
PORT=$(shuf -i8000-9999 -n1)
while lsof -i:${PORT} >/dev/null 2>&1; do
    PORT=$(shuf -i8000-9999 -n1)
done

export JUPYTER_PORT=${PORT}

echo "=== Jupyter job started at $(date) on ${IP}:${PORT} ==="

# Start idle killer
/share/apps/packages/jupyter-idle-killer >> "${HOME}/.sjupyter/jobs/${SLURM_JOB_ID}.idle.log" 2>&1 &
IDLE_KILLER_PID=$!
echo "Idle killer started (PID ${IDLE_KILLER_PID})"
trap "kill ${IDLE_KILLER_PID} 2>/dev/null || true" EXIT

# ---- Launch Jupyter (Lab preferred) ----------------------------------------
# ---- Launch Jupyter (Lab preferred) ----------------------------------------
if command -v jupyter-lab >/dev/null 2>&1; then
    echo "Starting JupyterLab..."
    jupyter-lab \
        --ip=$(hostname -i) \
        --port=${JUPYTER_PORT} \
        --no-browser \
        --ServerApp.log_level=INFO \
        --ServerApp.allow_remote_access=True \
        --ServerApp.default_url="/lab" \
        --ServerApp.use_redirect_file=False \
        --LabApp.default_url="/lab" \
	2>&1 | grep --line-buffered -v -E 'file://|http://127\.0\.0\.1|To access the server|Use Control-C|DeprecationWarning|return t\.cast' >> "${HOME}/.sjupyter/jobs/${SLURM_JOB_ID}.out" &
    JUPYTER_PID=$!
    echo "Jupyter started (PID ${JUPYTER_PID}) on http://${IP}:${PORT}"
else
    echo "jupyter-lab not found; falling back to jupyter-notebook."
    jupyter-notebook \
        --no-browser \
        --port="${PORT}" \
        --ip="${IP}" \
        --NotebookApp.log_level=INFO \
        --NotebookApp.use_redirect_file=False \
        --NotebookApp.default_url="/tree" \
	2>&1 | grep --line-buffered -v -E 'file://|http://127\.0\.0\.1|To access the server|Use Control-C|DeprecationWarning|return t\.cast' >> "${HOME}/.sjupyter/jobs/${SLURM_JOB_ID}.out" &
    JUPYTER_PID=$!
    echo "Jupyter started (PID ${JUPYTER_PID}) on http://${IP}:${PORT}"
fi

wait ${JUPYTER_PID}
EOF

# ---- Client-side: parse job ID ----------------------------------------------
SJUPYTER_JOBID=$(cut -d: -f1 "${SJUPYTER_TMPFILE}")
rm -f "${SJUPYTER_TMPFILE}"

echo "Submitted Jupyter job ${SJUPYTER_JOBID}"
echo "Waiting for startup..."

# Wait for job to enter RUNNING
for i in {1..90}; do
    state=$(squeue -j "${SJUPYTER_JOBID}" -h -o %t 2>/dev/null || echo "")
    if [[ "${state}" == "R" ]]; then
        echo "Job is running."
        break
    fi
    sleep 1
    echo -n "."
done
echo

OUTFILE="${SJUPYTER_USER_DIR}/jobs/${SJUPYTER_JOBID}.out"
echo "Waiting for Jupyter to initialize..."
TIMEOUT=${SJUPYTER_TIMEOUT:-120}
for i in $(seq 1 ${TIMEOUT}); do
    if grep -qE "http://[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+:[0-9]+/(lab|tree|)\?token=" "${OUTFILE}" 2>/dev/null; then
        TOKEN=$(grep -oE 'token=[a-f0-9]+' "${OUTFILE}" 2>/dev/null | head -1 | cut -d= -f2 || true)
        IP=$(grep -oE 'http://[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+:[0-9]+' "${OUTFILE}" 2>/dev/null | head -1 | grep -oE '[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+' || true)
        PORT=$(grep -oE 'http://[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+:[0-9]+' "${OUTFILE}" 2>/dev/null | head -1 | grep -oE '[0-9]+$' || true)
        break
    fi
    state=$(squeue -j "${SJUPYTER_JOBID}" -h -o %t 2>/dev/null || echo "")
    if [[ "${state}" != "R" && "${state}" != "CG" ]]; then
        echo "Job is no longer running. Check: ${OUTFILE}"
        exit 1
    fi
    if [ "${i}" -eq "${TIMEOUT}" ]; then
        echo "Timed out waiting for Jupyter. Check: ${OUTFILE}"
        scancel "${SJUPYTER_JOBID}"
        exit 1
    fi
    sleep 1
    echo -n "."
done
echo

TOKEN_URL="http://${IP}:${PORT}/lab?token=${TOKEN}"
echo "────────────────────────────────────"
echo "✅ Jupyter is ready!"
echo
echo "Access URLs:"
echo "   • JupyterLab:      http://${IP}:${PORT}/lab?token=${TOKEN}"
echo "   • Classic Notebook: http://${IP}:${PORT}/tree?token=${TOKEN}"
echo
echo "SSH tunnel from your laptop:"
echo "   (If off-campus, connect to the Columbia VPN first)"
HOST=$(squeue -j ${SJUPYTER_JOBID} -h -o %N)
echo "   ssh -L ${PORT}:${IP}:${PORT} -N -f ${USER}@${HOST}.rc.zi.columbia.edu"
echo "   Then open: http://127.0.0.1:${PORT}/lab?token=${TOKEN}"
echo
echo "SLURM output: ${OUTFILE}"
echo "Idle killer:   ${OUTFILE%.out}.idle.log"
echo "To stop:       scancel ${SJUPYTER_JOBID}"
echo
echo "⚠️  Reminder: This SSH tunnel will stay open on your laptop until you close it."
echo "    To close it, run on your laptop:"
echo "        pkill -f \"ssh -L ${PORT}:${IP}:${PORT}\""
echo "    Or kill all Jupyter SSH tunnels:"
echo "        pkill -f \"ssh -L\""
